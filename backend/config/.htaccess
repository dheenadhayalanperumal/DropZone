# Block all direct HTTP access to this folder — it must only be reached
# via PHP require/include from the front controller (backend/public/index.php)
# or the CLI (cron/migrate scripts), never as a URL.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>
